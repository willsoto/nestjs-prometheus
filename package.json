{
  "name": "@willsoto/nestjs-prometheus",
  "version": "6.1.0",
  "description": "NestJS module for Prometheus",
  "license": "Apache-2.0",
  "author": "Will Soto <willsoto@users.noreply.github.com> (https://github.com/willsoto)",
  "repository": "git://github.com/willsoto/nestjs-prometheus.git",
  "files": [
    "dist",
    "typings"
  ],
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "pnpm run clean",
    "build": "tsc --project tsconfig.build.json",
    "clean": "rimraf dist coverage",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --fix",
    "prepare": "lefthook install",
    "prerelease": "pnpm run build",
    "release": "semantic-release",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.lint.json --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@fastify/compress": "9.0.0",
    "@nestjs/cli": "11.0.23",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-fastify": "11.1.27",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/node": "24.13.2",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "lefthook": "2.1.9",
    "markdown-toc": "1.2.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "@nestjs/common": "^7.0.0 || ^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "prom-client": "^15.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      "@semantic-release/npm",
      "@semantic-release/changelog",
      "@semantic-release/git"
    ]
  },
  "packageManager": "pnpm@10.34.4"
}
